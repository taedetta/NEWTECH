# Copy to .env and fill in values (never commit .env)

# Required — Neon PostgreSQL from Render dashboard
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Required for auth tokens (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=change-me-to-a-long-random-string

PORT=3000
NODE_ENV=development
APP_ENV=production
APP_URL=http://localhost:3000

# Transactional email via SMTP (free tier: Brevo 300/day, Gmail app password, etc.)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-login
SMTP_PASS=your-smtp-password
SMTP_FROM=notifications@newtechaviation.com
EMAIL_FROM_NAME=New Tech Aviation

# Optional — R2 image uploads (live CMS already uses R2 URLs)
# POLSIA_R2_BASE_URL=https://pub-629428d185ca4960a0a73c850d32294b.r2.dev
# POLSIA_API_KEY=
