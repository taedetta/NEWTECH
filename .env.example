# Copy to .env and fill in values (never commit .env)

# Required — Neon PostgreSQL from Render dashboard
DATABASE_URL=postgresql://user:pass@host/db?sslmode=require

# Required for auth tokens (generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=change-me-to-a-long-random-string

PORT=3000
NODE_ENV=development
APP_ENV=production
APP_URL=http://localhost:3000

# Transactional email — Brevo REST API (preferred) or SMTP fallback
BREVO_API_KEY=xkeysib-your-key-here
SMTP_FROM=aviationnewtech@gmail.com
EMAIL_FROM_NAME=New Tech Aviation

# Full data backup recipient (CSV ZIP emailed before reset + nightly)
DATA_BACKUP_EMAIL=aviationnewtech@gmail.com

# SMTP fallback (optional if using BREVO_API_KEY)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-login
SMTP_PASS=your-smtp-password

# Optional — R2 image uploads (live CMS already uses R2 URLs)
# POLSIA_R2_BASE_URL=https://pub-629428d185ca4960a0a73c850d32294b.r2.dev
# POLSIA_API_KEY=
